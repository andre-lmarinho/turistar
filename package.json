{
  "name": "travel-planner",
  "version": "0.1.0",
  "private": true,
  "repository": "https://github.com/andre-lmarinho/travel-planner",
  "engines": {
    "node": "20.x",
    "npm": ">=10 <11"
  },
  "packageManager": "npm@10.9.3",
  "scripts": {
    "dev": "TAILWIND_CONFIG=config/tailwind.config.ts POSTCSS_CONFIG=config/postcss.config.mjs next dev --turbopack",
    "build": "TAILWIND_CONFIG=config/tailwind.config.ts POSTCSS_CONFIG=config/postcss.config.mjs next build",
    "start": "next start",
    "clean": "rimraf .next node_modules",
    "setup": "npm install && npm run format && npm run lint && npm run test",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"tests/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"tests/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint": "eslint . --ext .ts,.tsx --cache --fix --config config/eslint.config.mjs",
    "lint:commit": "commitlint --config config/commitlint.config.js --from=HEAD~1 --to=HEAD",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config config/vitest.config.ts",
    "test:watch": "vitest --watch --config config/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config config/vitest.config.ts",
    "prepare": "husky install",
    "gen:types": "supabase gen types typescript --project-id YOUR_ID --schema public > src/types/supabase.ts",
    "vercel:pull": "npx vercel@latest pull --yes --environment=preview",
    "vercel:build": "npx vercel@latest build --debug",
    "check:vercel": "npm run vercel:pull && npm run vercel:build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.53.0",
    "@tanstack/react-query": "^5.81.5",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "focus-trap-react": "^11.0.4",
    "framer-motion": "^12.23.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.525.0",
    "next": "15.3.4",
    "react": "^19.0.0",
    "react-day-picker": "^9.7.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "*",
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.81.5",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/leaflet": "^1.9.20",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "commitlint-config-gitmoji": "*",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.4.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "gitmoji-cli": "*",
    "husky": "^8.0.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
