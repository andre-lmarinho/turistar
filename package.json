{
  "name": "travel-planner",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "repository": "https://github.com/andre-lmarinho/travel-planner",
  "engines": {
    "node": "20.x",
    "npm": ">=10 <11"
  },
  "packageManager": "npm@10.9.3",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:e2e": "NEXT_PUBLIC_E2E=1 next dev --turbopack --port 3100",
    "build": "next build",
    "build:prod": "next build",
    "start": "next start",
    "serve:prod": "next start --hostname 0.0.0.0 --port 3000",
    "clean": "rimraf .next node_modules",
    "setup": "npm install && npm run format && npm run lint && npm run test",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:ci": "tsc --noEmit --pretty false",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest --watch -c vitest.config.ts",
    "e2e": "playwright test -c playwright.config.ts",
    "e2e:update": "playwright test -c playwright.config.ts --update-snapshots",
    "lhci": "npx --yes @lhci/cli@0.14.0 autorun --config=./lighthouserc.json",
    "gen:types": ": \"${SUPABASE_PROJECT_ID:?Set SUPABASE_PROJECT_ID}\" && supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" --schema public > src/shared/types/supabase.ts",
    "vercel:pull": "npx vercel@latest pull --yes --environment=preview",
    "vercel:build": "npx vercel@latest build --debug",
    "check:vercel": "npm run vercel:pull && npm run vercel:build",
    "lint-staged": "lint-staged",
    "postinstall": "husky install"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/mdx": "^3.1.1",
    "@next/mdx": "^16.2.4",
    "@sindresorhus/slugify": "^3.0.0",
    "@supabase/auth-helpers-react": "^0.15.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.100.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.12.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6",
    "vite": "^8.0.16",
    "vitest": "^4.0.4"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
