{
  "name": "travel-planner",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "repository": "https://github.com/andre-lmarinho/travel-planner",
  "engines": {
    "node": "20.x",
    "npm": ">=10 <11"
  },
  "packageManager": "npm@10.9.3",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:e2e": "NEXT_PUBLIC_E2E=1 next dev --turbopack --port 3100",
    "build": "next build",
    "build:prod": "next build",
    "start": "next start",
    "serve:prod": "next start --hostname 0.0.0.0 --port 3000",
    "clean": "rimraf .next node_modules",
    "setup": "npm install && npm run format && npm run lint && npm run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "eslint . -c eslint.config.mjs --ext .ts,.tsx --cache --cache-location .cache/.eslintcache --max-warnings=0",
    "lint:file": "eslint -c eslint.config.mjs --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "typecheck:ci": "tsc --noEmit --pretty false",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest --watch -c vitest.config.ts",
    "e2e": "playwright test -c playwright.config.ts",
    "e2e:update": "playwright test -c playwright.config.ts --update-snapshots",
    "warmup": "bash ./scripts/warmup.sh",
    "lhci": "npx --yes @lhci/cli@0.14.0 autorun --config=./lighthouserc.json",
    "gen:types": ": \"${SUPABASE_PROJECT_ID:?Set SUPABASE_PROJECT_ID}\" && supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" --schema public > src/types/supabase.ts",
    "vercel:pull": "npx vercel@latest pull --yes --environment=preview",
    "vercel:build": "npx vercel@latest build --debug",
    "check:vercel": "npm run vercel:pull && npm run vercel:build",
    "lint-staged": "lint-staged",
    "prepare": "node ./scripts/prepare-husky.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/mdx": "^3.1.1",
    "@next/mdx": "^16.0.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@sindresorhus/slugify": "^3.0.0",
    "@supabase/auth-helpers-react": "^0.15.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.87.3",
    "@tanstack/react-query": "^5.90.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.26",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.561.0",
    "next": "^16.0.10",
    "react": "^19.2.3",
    "react-day-picker": "^9.12.0",
    "react-dom": "^19.2.3",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^7.3.0",
    "vitest": "^4.0.4"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "endOfLine": "auto",
    "plugins": [
      "prettier-plugin-tailwindcss"
    ],
    "tailwindFunctions": [
      "cva"
    ]
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
