{
  "name": "travel-planner",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "repository": "https://github.com/andre-lmarinho/travel-planner",
  "engines": {
    "node": ">=24.11.1 <25",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "next dev",
    "dev:e2e": "NEXT_PUBLIC_E2E=1 next dev --port 3100",
    "build": "next build",
    "start": "next start",
    "serve:prod": "next start --hostname 0.0.0.0 --port 3000",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "next typegen && tsc --noEmit",
    "typecheck:ci": "next typegen && tsc --noEmit --pretty false",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "e2e": "playwright test",
    "gen:types": ": \"${SUPABASE_PROJECT_ID:?Set SUPABASE_PROJECT_ID}\" && supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" --schema public > src/shared/types/supabase.ts",
    "vercel:pull": "pnpm dlx vercel@56.0.0 pull --yes --environment=preview",
    "vercel:build": "pnpm dlx vercel@56.0.0 build --debug",
    "check:vercel": "pnpm vercel:pull && pnpm vercel:build",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/mdx": "^3.1.1",
    "@next/mdx": "^16.2.10",
    "@sindresorhus/slugify": "^3.0.0",
    "@supabase/auth-js": "^2.110.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6",
    "vite": "^8.1.4",
    "vitest": "^4.0.4"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
