{
  "name": "travel-planner",
  "version": "0.1.0",
  "private": true,
  "repository": "https://github.com/andre-lmarinho/travel-planner",
  "engines": {
    "node": "20.x",
    "npm": ">=10 <11"
  },
  "packageManager": "npm@10.9.3",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:prod": "next build",
    "start": "next start",
    "serve:prod": "next start --hostname 0.0.0.0 --port 3000",
    "clean": "rimraf .next node_modules",
    "setup": "npm install && npm run format && npm run lint && npm run test",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"tests/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"tests/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint": "eslint . -c config/eslint.config.mjs --ext .ts,.tsx --cache --cache-location .cache/.eslintcache --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run -c config/vitest.config.ts",
    "test:watch": "vitest --watch -c config/vitest.config.ts",
    "test:coverage": "vitest run --coverage -c config/vitest.config.ts",
    "warmup": "bash ./scripts/warmup.sh",
    "lhci": "npx --yes @lhci/cli@0.14.0 autorun --config=./lighthouserc.json",
    "prepare": "husky install",
    "gen:types": "supabase gen types typescript --project-id YOUR_ID --schema public > src/types/supabase.ts",
    "vercel:pull": "npx vercel@latest pull --yes --environment=preview",
    "vercel:build": "npx vercel@latest build --debug",
    "check:vercel": "npm run vercel:pull && npm run vercel:build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-query": "^5.81.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "focus-trap-react": "^11.0.4",
    "framer-motion": "^12.23.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.544.0",
    "next": "^15.5.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.11.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.81.5",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/leaflet": "^1.9.20",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.36.0",
    "eslint-config-next": "^15.4.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^8.0.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "endOfLine": "auto",
    "plugins": [
      "prettier-plugin-tailwindcss"
    ],
    "tailwindFunctions": [
      "cva"
    ]
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
