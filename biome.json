{
  "$schema": "https://biomejs.dev/schemas/2.3.13/schema.json",
  "root": true,
  "css": {
    "parser": {
      "tailwindDirectives": true,
      "cssModules": true
    }
  },
  "formatter": {
    "includes": ["**/*"],
    "lineWidth": 110,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf"
  },
  "files": {
    "includes": [
      "**/*",
      "!!**/node_modules",
      "!!**/.next",
      "!!**/public",
      "!!public",
      "!!*.log",
      "!!.gitignore",
      "!!.npmignore",
      "!!test-results"
    ],
    "ignoreUnknown": true
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": true,
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "next": "recommended",
      "react": "recommended"
    },
    "rules": {
      "recommended": true,
      "nursery": {
        "noUnresolvedImports": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.tsx"],
      "javascript": {
        "jsxRuntime": "transparent"
      }
    },
    {
      "includes": ["src/modules/**/*.{ts,tsx,js,jsx,mts,mjs,cjs,cts}"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off",
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/app/**"],
                    "message": "Modules should not import from app to avoid circular dependencies."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/**/*.{ts,tsx,js,jsx,mts,mjs,cjs,cts}"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off",
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/app/**"],
                    "message": "Features should not import from app to avoid circular dependencies."
                  },
                  {
                    "group": ["@/modules/**"],
                    "message": "Features should not import from modules to avoid circular dependencies."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/shared/**/*.{ts,tsx,js,jsx,mts,mjs,cjs,cts}"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off",
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/app/**"],
                    "message": "Shared should not import from app to avoid circular dependencies."
                  },
                  {
                    "group": ["@/modules/**"],
                    "message": "Shared should not import from modules to avoid circular dependencies."
                  },
                  {
                    "group": ["@/features/**"],
                    "message": "Shared should not import from features to avoid circular dependencies."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
