# Example environment variables for Turistar
NEXT_PUBLIC_GEOAPIFY_KEY=your_api_key_here
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_SUPABASE_CLIENT_OPTIONS={"persistSession":true}

# Vercel CLI token for non-interactive usage (CI/local)
# Leave empty locally if you're logged in via `vercel login`.
VERCEL_TOKEN=

# Optional canonical public site URL.
# - Leave UNSET in local development; it defaults to http://localhost:3000
# - For production/staging with a custom domain, set a full URL (no trailing slash), e.g.:
#   NEXT_PUBLIC_SITE_URL=https://travel.turistar.app
NEXT_PUBLIC_SITE_URL=
