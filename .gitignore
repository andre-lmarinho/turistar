# Core dependencies & build
node_modules/
.next/
out/                # `next export`
build/              # qualquer pasta de build custom

# Package managers (npm only)
.pnpm*              # artefatos se tiver rodado pnpm por engano
.yarn/              # idem para Yarn (berry)

# Tooling & cache
.turbo/             # Turbopack/Turborepo cache
.eslintcache
/.cache/
*.tsbuildinfo       # TypeScript incremental
tsconfig.tsbuildinfo

# Testing / E2E
coverage/
lhci-reports/
playwright-report/
test-results/
cypress/videos/
cypress/screenshots/

# Environment & secrets

/.env.local         # .env, .env.local, etc.
**/.env.local    
!.env.example
.vercel/            # Vercel build output & metadata
.vercel-build-tmp/  # temporary worktree used by pre-commit build

# Editors / OS
.vscode/
.idea/
.DS_Store
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# npm oddities occasionally created on Windows
.ignored_node_modules/
.vercel
